<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Students </title>
</head>
<body>
    <h1>All Students</h1>
    <ul>
        <% students.forEach(student => { %>
            <li> <%=student.student_id%> <%= student.full_name %> - <%= student.email %></li>
        <% }) %>

    </ul>
</body>
</html>